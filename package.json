{
	"name": "threat-forge",
	"private": true,
	"version": "0.2.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"dev:web": "vite --port 3000",
		"build": "tsc && vite build",
		"build:web": "tsc && vite build",
		"preview": "vite preview",
		"preview:web": "npm run build:web && wrangler dev",
		"deploy:web": "npm run build:web && wrangler deploy",
		"check:worker": "wrangler deploy --dry-run",
		"tauri": "tauri",
		"check:lockfile": "node scripts/check-lockfile-registry.mjs",
		"check:tauri-versions": "node scripts/check-tauri-version-alignment.mjs",
		"check": "biome check .",
		"format": "biome check --write .",
		"test": "vitest --run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"ci:local": "bash scripts/ci-local.sh",
		"ci:docker": "docker compose run --rm --build ci",
		"ci:docker:build": "docker compose run --rm --build ci bash scripts/ci-local.sh --build",
		"prepare": "bash scripts/setup-hooks.sh"
	},
	"dependencies": {
		"@tauri-apps/api": "2.11.1",
		"@tauri-apps/plugin-dialog": "2.7.2",
		"@tauri-apps/plugin-opener": "2.5.4",
		"@xyflow/react": "^12.10.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"js-yaml": "^4.1.1",
		"lucide-react": "^0.575.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.13.1",
		"remark-gfm": "^4.0.1",
		"tailwind-merge": "^3.5.0",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/vite": "^4.2.1",
		"@tauri-apps/cli": "2.11.4",
		"@testing-library/jest-dom": "^7.0.0",
		"@testing-library/react": "^16.3.2",
		"@types/js-yaml": "^4.0.9",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^4.3.4",
		"jsdom": "^28.1.0",
		"tailwindcss": "^4.2.1",
		"typescript": "~5.6.2",
		"vite": "^6.0.3",
		"vitest": "^4.0.18",
		"wrangler": "4.107.1"
	}
}
