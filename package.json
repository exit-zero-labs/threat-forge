{
	"name": "threat-forge",
	"private": true,
	"version": "0.2.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"dev:web": "vite --port 3000",
		"build": "tsc && vite build",
		"build:web": "tsc && vite build",
		"preview": "vite preview",
		"preview:web": "npm run build:web && wrangler dev",
		"deploy:web": "npm run build:web && wrangler deploy",
		"check:worker": "wrangler deploy --dry-run",
		"check:worker-types": "wrangler types --include-runtime=false --check ./worker/worker-configuration.d.ts && tsc --noEmit -p tsconfig.worker.json",
		"tauri": "tauri",
		"check:lockfile": "node scripts/check-lockfile-registry.mjs",
		"check:tauri-versions": "node scripts/check-tauri-version-alignment.mjs",
		"check": "biome check .",
		"format": "biome check --write .",
		"test": "vitest --run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"ci:local": "bash scripts/ci-local.sh",
		"ci:docker": "docker compose run --rm --build ci",
		"ci:docker:build": "docker compose run --rm --build ci bash scripts/ci-local.sh --build",
		"prepare": "bash scripts/setup-hooks.sh"
	},
	"dependencies": {
		"@tauri-apps/api": "2.11.1",
		"@tauri-apps/plugin-clipboard-manager": "2.3.2",
		"@tauri-apps/plugin-dialog": "2.7.2",
		"@tauri-apps/plugin-opener": "2.5.4",
		"@xyflow/react": "^12.10.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"js-yaml": "^5.2.1",
		"lucide-react": "^1.25.0",
		"react": "^19.2.8",
		"react-dom": "^19.2.8",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.13.1",
		"remark-gfm": "^4.0.1",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.4.3",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.5",
		"@cloudflare/workers-types": "5.20260721.1",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/vite": "^4.2.1",
		"@tauri-apps/cli": "2.11.4",
		"@testing-library/jest-dom": "^7.0.0",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"fake-indexeddb": "6.2.5",
		"jsdom": "^29.1.1",
		"tailwindcss": "^4.2.1",
		"typescript": "~7.0.2",
		"vite": "^8.1.5",
		"vitest": "^4.0.18",
		"wrangler": "4.113.0"
	}
}
