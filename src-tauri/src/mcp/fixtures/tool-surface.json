          ]
        },
        "element_type": {
          "description": "New type",
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "description": "ID of the element to update",
          "type": "string"
        },
        "name": {
          "description": "New name",
          "type": [
            "string",
            "null"
          ]
        },
        "trust_zone": {
          "description": "New trust zone",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
