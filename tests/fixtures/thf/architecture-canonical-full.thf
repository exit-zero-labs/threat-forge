  stroke_opacity: 0.95
data_flows:
- id: flow-1
  flow_number: 1
  name: Checkout request
  from: web-app
  to: api-gateway
  protocol: HTTPS/TLS-1.3
  data:
  - order_request
  authenticated: true
  label_offset:
    x: 12.0
    y: -6.0
  source_handle: right
  target_handle: left
  stroke_color: '#ef4444'
  stroke_opacity: 0.85
- id: flow-2
  flow_number: 2
  name: Persist order
  from: api-gateway
  to: orders-db
  protocol: PostgreSQL/TLS
  data:
  - order_records
  authenticated: true
relationships:
- id: rel-1
  type: deploys_to
  from: api-gateway
  to: orders-db
  name: Runs alongside
  description: Gateway is deployed in the same cluster as the store
  source_handle: bottom
  target_handle: top
  label_offset:
    x: 8.0
    y: 4.0
  stroke_color: '#64748b'
  stroke_opacity: 0.5
- id: rel-2
  type: depends_on
  from: web-app
  to: orders-db
