  group: frontend-cluster
  description: React storefront
  technologies:
  - react
  - vite
  tags:
  - tier-1
  position:
    x: 100.0
    y: 120.0
- id: api-gateway
  type: process
  name: API Gateway
  trust_zone: dmz
  layer: application
  group: api-subcluster
  subtype: api_gateway
  icon: router
