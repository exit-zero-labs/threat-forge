  description: "Pre-inline-layout document; positions live in the sidecar JSON."
elements:
  - id: web-app
    type: process
    name: "Web App"
    trust_zone: internal
  - id: db
    type: data_store
    name: "Database"
    trust_zone: internal
    stores: [session_records]
data_flows:
