# ThreatForge Threat Model
# Cross-emitter fixture: v1.0-canonical-full.thf after a browser open and save.
# Generated by the browser writer; do not hand-edit. See README.md.
version: "1.0"
metadata:
  title: Payment Processing Service
  author: Alex Chen
  created: 2026-03-15
  modified: 2026-03-20
  description: |
    Threat model for the payment processing microservice
    that handles credit card transactions via Stripe API.
  created_by: Alex Chen <alex@example.com>
  modified_by: Priya Raman <priya@example.com>
  last_edit_timestamp: 1742486400
  settings:
    grid_size: 24
    default_element_fill: "#3b82f6"
    default_element_stroke: "#1e40af"
    default_boundary_fill: "#22c55e"
    default_boundary_stroke: "#15803d"
elements:
  - id: web-app
    type: process
    name: Web Application
    trust_zone: internal
    description: React frontend served via CDN
    technologies:
      - react
      - vite
    position:
      x: 100
      "y": 200
  - id: api-gateway
    type: process
    name: API Gateway
    trust_zone: dmz
    subtype: api_gateway
    icon: router
    description: Terminates TLS and enforces rate limits
    technologies:
      - nginx
      - rate-limiting
    position:
      x: 400
      "y": 200
    fill_color: "#3b82f6"
    stroke_color: "#1e40af"
    fill_opacity: 0.15
    stroke_opacity: 0.9
  - id: payment-db
    type: data_store
    name: Payment Database
    trust_zone: internal
    subtype: sql_database
    icon: database
    description: Primary transactional store
    technologies:
      - postgresql
    stores:
      - transaction_records
      - tokenized_card_data
    encryption: AES-256-at-rest
    position:
      x: 700
      "y": 200
    fill_color: "#22c55e"
    stroke_color: "#15803d"
    fill_opacity: 0.2
    stroke_opacity: 0.95
    font_size: 14
    font_weight: normal
  - id: stripe-api
    type: external_entity
    name: Stripe API
    trust_zone: external
    description: Third-party payment processor
    position:
      x: 700
      "y": 420
    technologies: []
  - id: note-1
    type: text
    name: PCI DSS scope boundary
    trust_zone: ""
    description: ""
    position:
      x: 60
      "y": 90
    fill_color: "#94a3b8"
    fill_opacity: 0.8
    font_size: 20
    font_weight: bold
    technologies: []
data_flows:
  - id: flow-1
    flow_number: 1
    name: Checkout request
    from: web-app
    to: api-gateway
    protocol: HTTPS/TLS-1.3
    data:
      - user_input
      - payment_request
    authenticated: true
    label_offset:
      x: 12
      "y": -6
    source_handle: right
    target_handle: left
    stroke_color: "#ef4444"
    stroke_opacity: 0.85
  - id: flow-2
    flow_number: 2
    name: Persist transaction
    from: api-gateway
    to: payment-db
    protocol: PostgreSQL/TLS
    data:
      - transaction_records
    authenticated: true
  - id: flow-3
    flow_number: 3
    name: Charge card
    from: api-gateway
    to: stripe-api
    protocol: HTTPS/TLS-1.3
    data:
      - tokenized_card_data
    authenticated: true
trust_boundaries:
  - id: boundary-1
    name: Corporate Network
    contains:
      - web-app
      - api-gateway
      - payment-db
    position:
      x: 50
      "y": 150
    size:
      width: 760
      height: 180
    fill_color: "#22c55e"
    stroke_color: "#15803d"
    fill_opacity: 0.1
    stroke_opacity: 0.6
  - id: boundary-2
    name: External Services
    contains:
      - stripe-api
    position:
      x: 650
      "y": 380
    size:
      width: 240
      height: 160
    fill_color: "#f97316"
    stroke_color: "#c2410c"
    fill_opacity: 0.12
    stroke_opacity: 0.7
threats:
  - id: threat-1
    title: SQL injection on payment queries
    category: Tampering
    element: api-gateway
    flow: flow-2
    severity: high
    description: |
      Malicious SQL could be injected through payment
      parameters if input validation is insufficient.
    mitigation:
      status: mitigated
      description: Parameterized queries via ORM; input validation layer
  - id: threat-2
    title: Man-in-the-middle on Stripe API calls
    category: Information Disclosure
    element: api-gateway
    flow: flow-3
    severity: medium
    description: API calls to Stripe could be intercepted in transit.
    mitigation:
      status: in_progress
      description: TLS 1.3 enforced; certificate pinning pending
  - id: threat-3
    title: Unauthenticated access to the admin console
    category: Elevation of Privilege
    element: web-app
    severity: critical
    description: The admin console is reachable without a second factor.
diagrams:
  - id: main-dfd
    name: Level 0 DFD
    viewport:
      x: -40
      "y": 25
      zoom: 0.85
