# ThreatForge Local CI — Ubuntu 22.04 + Node 22 + Rust stable + Tauri system deps.
#
# Layer order optimized for Docker cache efficiency:
#   1. System deps (rarely change)
#   2. Node 22 via NodeSource
#   3. Rust stable + clippy + rustfmt
#   4. npm ci (cached until dependency policy inputs change)
#   5. cargo fetch (cached until Cargo.lock changes)
#   6. Full source copy (rebuilds on any source change)

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# 1. System dependencies for Tauri + WebKit
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    ca-certificates \
    gnupg \
    pkg-config \
    libwebkit2gtk-4.1-dev \
    libappindicator3-dev \
    librsvg2-dev \
    patchelf \
    libdbus-1-dev \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# 2. Node 22 via NodeSource
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# 3. Rust stable + clippy + rustfmt
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y \
    --default-toolchain stable \
    --component clippy,rustfmt
ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /app

# 4. npm ci + Playwright (cached until dependency policy changes)
COPY package.json package-lock.json .npmrc ./
COPY scripts/check-lockfile-registry.mjs scripts/setup-hooks.sh scripts/
RUN node scripts/check-lockfile-registry.mjs
RUN npm ci
RUN npx playwright install --with-deps chromium

# 5. cargo fetch (cached until Cargo.lock changes)
COPY src-tauri/Cargo.toml src-tauri/Cargo.lock src-tauri/
COPY src-tauri/build.rs src-tauri/
# Stub out src so cargo fetch can resolve the workspace
RUN mkdir -p src-tauri/src && echo "fn main() {}" > src-tauri/src/main.rs && echo "" > src-tauri/src/lib.rs
RUN cd src-tauri && cargo fetch --locked
RUN rm -rf src-tauri/src

# 6. Full source copy
COPY . .

# Headless WebKit env vars for Docker builds
ENV WEBKIT_DISABLE_COMPOSITING_MODE=1
ENV WEBKIT_DISABLE_DMABUF_RENDERER=1

CMD ["bash", "scripts/ci-local.sh"]
