{
	"compilerOptions": {
		"target": "ES2020",
		"useDefineForClassFields": true,
		/* `ES2022.Object` declares `Object.hasOwn`, the own-property guard Biome's
		   `noPrototypeBuiltins` requires. It needs Safari 15.4, which the app
		   already requires for `structuredClone`, so the runtime floor is unchanged. */
		"lib": ["ES2020", "ES2022.Object", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"skipLibCheck": true,

		/* Bundler mode */
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",

		/* Path aliases */
		"paths": {
			"@/*": ["./src/*"]
		},

		/* Linting */
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true
	},
	"include": ["src"],
	"references": [{ "path": "./tsconfig.node.json" }]
}
